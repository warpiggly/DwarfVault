{
  "manifest_version": 3,
  "name": "The Dwarf's Vault",
  "version": "1.2",
   "commands": {
        "open-extension": {
            "suggested_key": {
                "default": "Ctrl+Y",
                "mac": "Command+Y"
            },
            "description": "Open the extension popup"
        }
    },

  "description": "Save, organize and instantly access selected text in local custom databases. Private, fast, and keyboard-friendly.",
  "short_description": "Save selected text to custom local databases. Private, fast, keyboard-friendly right-click vault.",
  "author": "David Salazar Saldarriaga (DearDeivy / Warpiggly)",
  "permissions": [
    "contextMenus",
    "storage",
    "scripting",
    "notifications",
    "tabs",
    "clipboardWrite",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'; frame-ancestors 'none'"
  }

}